# psobb-studio environment — copy to .env and fill in your local paths.
# Paths are resolved at runtime; NEVER hardcode these in source. .env is gitignored.

# --- Repo / reference roots ---
PSOBB_STUDIO_ROOT=/path/to/psobb-studio
PSOBB_HARNESS_ROOT=/path/to/psoharness
PSOBB_CLIENT_SRC_ROOT=/path/to/psobb-client-source
PSOBB_DECOMPILE_ROOT=/path/to/psobb-client-decompile
NEWSERV_ROOT=/path/to/newserv

# --- Data roots ---
PSO_LIVE_DATA_DIR=/path/to/PSOBB/data        # live install — read-only except explicit deploy
PSO_DEV_DATA_DIR=/tmp/pso_dev                 # scratch write target
PSO_DATA_DIR=                                 # overrides LIVE/DEV when set
PSOBB_CLIENT_DIR=/path/to/client              # dir containing the game binary
PSOBB_DOWNLOADS_DIR=/path/to/downloads        # source assets (GLB/FBX/ZIP)

# --- External tools (optional; sensible defaults baked in, override per machine) ---
PSO_PUYOTOOLS=                                 # PuyoToolsCli.exe — PRS compress / archive ops
PSO_XVR_CODEC=                                 # xvr_codec.py — XVM extract / rebuild
PSO_REALESRGAN=                                # realesrgan-ncnn-vulkan.exe — texture upscale

# --- Flags ---
PSOBB_SCAFFOLD_LIVE=0                          # 1 enables live newserv/client/harness gates

# --- AI providers (P5) — names only; real keys go in .env, never committed ---
AIGEN_SESSION_BUDGET_USD=0
AIGEN_DAILY_BUDGET_USD=0
STABILITY_API_KEY=
COMFYUI_URL=http://127.0.0.1:8188
